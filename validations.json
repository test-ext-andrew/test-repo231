{
  "name": "Node name refs example",
  "steps": [
    {
      "name": "start",
      "type": "TRIGGER",
      "next": [{ "step": "extract_invoice" }]
    },
    {
      "name": "extract_invoice",
      "type": "EXTRACT",
      "config": {
        "extractor": {
          "id": "dp_replace_with_extractor_id",
          "version": "draft"
        }
      },
      "next": [{ "step": "validate_invoice" }]
    },
    {
      "name": "validate_invoice",
      "type": "VALIDATION",
      "config": {
        "blocks": [
          {
            "id": "block_total_present",
            "name": "Total amount is present",
            "blockType": "code",
            "code": {
              "language": "javascript",
              "code": "const total = context.outputs.extract_invoice.total_amount?.value?.amount;\nreturn [typeof total === 'number' && total > 0, 'total_amount must be present and positive'];"
            }
          },
          {
            "id": "block_vendor_plausible",
            "name": "Vendor is plausible",
            "blockType": "semantic",
            "semantic": {
              "promptText": "The vendor {{ outputs.extract_invoice.vendor_name.value }} should look like a plausible company name for an invoice."
            }
          }
        ]
      },
      "next": [
        { "step": "route_invoice", "result": "pass" },
        { "step": "failed_response", "result": "fail" }
      ]
    },
    {
      "name": "route_invoice",
      "type": "ROUTER",
      "config": {
        "branches": [
          {
            "id": "high_value",
            "name": "High value invoice",
            "block": {
              "id": "block_high_value",
              "name": "Total over 10000",
              "blockType": "code",
              "code": {
                "language": "javascript",
                "code": "return context.outputs.extract_invoice.total_amount.value.amount >= 10000;"
              }
            }
          },
          {
            "id": "acme_vendor",
            "name": "ACME vendor",
            "block": {
              "id": "block_acme_vendor",
              "name": "Vendor mentions ACME",
              "blockType": "semantic",
              "semantic": {
                "promptText": "The vendor name {{ outputs.extract_invoice.vendor_name.value }} refers to ACME or an ACME-related entity."
              }
            }
          }
        ]
      },
      "next": [
        { "step": "review_response", "branchId": "high_value" },
        { "step": "review_response", "branchId": "acme_vendor" },
        { "step": "passed_response", "branchId": "otherwise" }
      ]
    },
    {
      "name": "passed_response",
      "type": "WEBHOOK_RESPONSE"
    },
    {
      "name": "review_response",
      "type": "WEBHOOK_RESPONSE"
    },
    {
      "name": "failed_response",
      "type": "WEBHOOK_RESPONSE"
    }
  ]
}
